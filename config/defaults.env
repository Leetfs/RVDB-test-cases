: "${AUTO_INSTALL:=1}"
: "${AUTO_INSTALL_SOURCE:=1}"
: "${RUN_SPEC:=1}"
: "${RUN_PTS:=1}"
: "${RUN_LTP:=1}"
: "${RUN_STRESS:=0}"
: "${RUN_GPU:=1}"
: "${RUN_STORAGE:=1}"
: "${RUN_DISTRO:=1}"
: "${RUN_TOOLCHAINS:=1}"
: "${RUN_NETWORK:=1}"
: "${RUN_CONTAINERS:=1}"
: "${RUN_CONTAINER_IMAGES:=1}"
: "${RUN_SECURITY:=1}"
: "${RUN_REALTIME:=1}"
: "${RUN_MULTIMEDIA:=1}"
: "${RUN_FILESYSTEM:=1}"
: "${RUN_KSELFTEST:=1}"
: "${RUN_GRAPHICS_CTS:=0}"
: "${RUN_DESTRUCTIVE:=0}"
: "${RUN_OPENSCAP:=0}"
: "${STRICT:=0}"
: "${STRESS_SECONDS:=300}"
: "${STORAGE_SIZE:=512M}"
: "${SPEC_AUTO_INIT:=1}"
: "${SPEC2017_ROOT:=}"
: "${SPEC2017_INSTALL_ROOT:=/home/leetfs/spec2017}"
: "${SPEC2017_MEDIA_URL:=https://smallquilt.quilt.idv.tw:8923/ouo/support/SPEC%20CPU%202017/CPU%202017%201.0.5.iso}"
: "${SPEC2017_SHA256_FILE:=config/cpu2017-1_0_5.iso.sha256}"
: "${SPEC2017_INSTALL_CMD:=}"
: "${SPEC2017_CONFIG:=auto}"
: "${SPEC2017_CMD:=runcpu --config=auto --size=ref intrate fprate}"
: "${PTS_TIER:=extended}"
: "${PTS_GROUPS:=cpu crypto compression memory storage toolchain runtime multimedia server kernel network}"
: "${PTS_TESTS=}" # 非空时覆盖目录选择，直接指定空格分隔的 profile。
: "${PTS_TIMES_TO_RUN:=1}"
: "${PTS_TEST_TIMEOUT:=4h}"
: "${KSELFTEST_COLLECTIONS:=breakpoints capabilities cgroup clone3 close_range exec fanotify filesystems futex ipc landlock mincore mount net nsfs pid_namespace pidfd proc pstore seccomp timers user}"
: "${REALTIME_SECONDS:=30}"
: "${CONTAINER_IMAGE:=docker.io/library/alpine:latest}"
: "${OPENSCAP_CONTENT:=}"
: "${OPENSCAP_PROFILE:=}"
: "${XFSTESTS_TEST_DEV:=}"
: "${XFSTESTS_SCRATCH_DEV:=}"
: "${BLKTESTS_DEVICES:=}"
